{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "admini-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-30",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "vars": {
    "SENTRY_ENVIRONMENT": "preview"
  }
}
