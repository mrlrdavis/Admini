{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "paths": {
      "@admini/shared": ["packages/shared/src/index.ts"],
      "@admini/privacy": ["packages/privacy/src/index.ts"],
      "@admini/api-client": ["packages/api-client/src/index.ts"],
      "@admini/ui": ["packages/ui/src/index.ts"],
      "@admini/integrations": ["packages/integrations/src/index.ts"],
      "@admini/workspace": ["packages/workspace/src/index.ts"],
      "@admini/pwa": ["packages/pwa/src/index.ts"]
    }
  }
}
